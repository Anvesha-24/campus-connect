MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/campusconnect
PORT=5000
JWT_SECRET=yourSuperSecretKey123

# Restrict CORS to your actual deployed frontend URL
CLIENT_URL=https://your-frontend.onrender.com

# Free token from https://huggingface.co/settings/tokens (Read access is enough)
# Used to generate sentence embeddings for semantic search
HF_API_TOKEN=your_huggingface_token_here

# Groq API key (same one from your other project) â€” used for RAG-generated answers
GROQ_API_KEY=your_groq_api_key_here

